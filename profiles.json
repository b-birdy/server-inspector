{
  "schema_version": "1.0",
  "tool_version": "v0.2",
  "_doc": "Server Inspector 外部配置：包含各类硬件的检测命令、解析正则、规格库。修改本文件可直接扩展脚本支持范围，无需改 Python 代码。",

  "platforms_supported": ["linux"],

  "bin_search_paths": [
    "/bin", "/usr/bin", "/sbin", "/usr/sbin",
    "/usr/local/bin", "/usr/local/sbin",
    "/opt/bin", "/snap/bin",
    "/opt/rocm/bin", "/opt/dtk/bin",
    "/opt/mxdriver/bin", "/opt/mthreads/bin",
    "/opt/cambricon/neuware/bin",
    "/usr/local/Ascend/driver/tools",
    "/usr/local/Ascend/ascend-toolkit/latest/bin"
  ],
  "_bin_search_note": "脚本会在这些目录 + 环境变量 $PATH 中搜索命令。如发现新加速卡 SDK 装在其他目录，添加到此列表即可。",

  "bin_categories": {
    "accelerator_smi": [
      "nvidia-smi", "rocm-smi", "amd-smi",
      "hy-smi", "dtk-smi", "rocminfo",
      "xpu-smi", "xpu_smi", "xpuinfo",
